# Neon / Postgres — paste your connection string (never commit .env)
# 生产/房间内低延迟：请使用 Neon「Pooled connection」串（主机名含 -pooler）
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# 连接池（可选）
# PG_POOL_MAX=12
# PG_CONNECT_TIMEOUT_MS=8000
# 服务端房间缓存 TTL（毫秒）
# ROOM_CACHE_APPT_MS=15000
# ROOM_CACHE_EMAIL_MS=300000
# ROOM_CACHE_ACCESS_MS=60000
# ROOM_INSTANT_EMPTY_GRACE_SECONDS=45
# Host booking tables: npm run db:migrate:host-invitations
# Appointments + participants: npm run db:migrate:appointments
# 原始游戏库种子（分类 + 游戏）：npm run db:seed:reference-catalog
PORT=8787
# 预约 scheduled_at 过后 N 小时自动删除房间（默认 6）
ROOM_AUTO_EXPIRE_HOURS=6
# 后台扫描间隔（毫秒，默认 900000 = 15 分钟）
# ROOM_EXPIRE_SWEEP_INTERVAL_MS=900000
# 现场房间全员离开后 N 秒删除（默认 45）
# ROOM_INSTANT_EMPTY_GRACE_SECONDS=45
# 同步抽奖动画时长（毫秒，默认 3500）
# ROOM_SPIN_DURATION_MS=3500

# Resend：https://resend.com — API Keys
# 发邀请邮件可用「仅发信」Key；同步 Clerk 到 Audience 联系人需带 Audiences（Contacts）权限的 Key（或全权限）
RESEND_API_KEY=
# Resend Audiences → 选中 Audience 后 URL 或详情中的 ID（同步 Clerk 新用户到联系人）
RESEND_AUDIENCE_ID=
# 发件人（需在 Resend 中验证的域名，例如：Glitchub <bookings@yourdomain.com>）
RESEND_FROM_EMAIL=
# 可选：预约邀请/取消邮件密送一封到你的邮箱（例如运维收件）
RESEND_HOST_INVITATION_BCC=boyan.24@ichat.sp.edu.sg
# 邮件内链接用的站点根 URL（可选，默认 http://localhost:5173）
APP_PUBLIC_ORIGIN=http://localhost:5173

# Clerk — https://dashboard.clerk.com → API Keys
# 前端（Vite 仅暴露 VITE_*）
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
# 后端专用，勿写入前端代码
CLERK_SECRET_KEY=sk_test_xxxxx
# Webhooks：Clerk Dashboard → Webhooks → Endpoint URL 填 https://你的域名/api/webhooks/clerk
# 建议订阅：user.created、user.updated（同步 Neon + Resend 联系人）
# 本地开发用 ngrok / cloudflared 把 https 指到本机 8787，再把「Signing Secret」贴到此处
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxx
# 可选：npm run test:clerk-user-sync 默认邮箱（也可用命令行参数传入）
# CLERK_SYNC_TEST_EMAIL=

# 组织游戏提案：盲投窗口（小时，默认 24）
# ORG_PROPOSAL_VOTING_HOURS=24
# 后台解析到期提案间隔（毫秒，默认 60000；设为 0 关闭定时器，仅懒解析）
# ORG_PROPOSAL_RESOLVE_INTERVAL_MS=60000
# POST /api/org-games/proposals/resolve 请求头 x-org-resolve-secret
ORG_PROPOSAL_RESOLVE_SECRET=
